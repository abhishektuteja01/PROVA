# Anthropic
# Server-side only — referenced exclusively in src/lib/anthropic/client.ts
ANTHROPIC_API_KEY=

# Supabase — public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase — server-side only — referenced exclusively in src/lib/supabase/server.ts
SUPABASE_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=

# Sentry (optional)
# NEXT_PUBLIC_SENTRY_DSN is used by sentry.client.config.ts (browser)
# SENTRY_DSN is used by instrumentation.ts (server/edge)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Rate limiting — compliance checks per user per hour (default: 10)
RATE_LIMIT_REQUESTS_PER_HOUR=10
